---
// Implements REQ-READ-006
//
// Empty-state page for when the LLM returned fewer than 3 articles.
// Linked from digest.astro via 303 redirect when the ready digest has
// less than the 3-article floor. Copy: "No stories today — try broader
// hashtags" with a direct link to /settings.

import Base from '~/layouts/Base.astro';
import { loadSession } from '~/middleware/auth';

// Load the authenticated user onto locals so the header (UserMenu +
// History icon) renders. Mirror the auth pattern from digest.astro:
// fail-closed with 500 when the OAUTH_JWT_SECRET is missing, route
// unauth visitors through the OAuth flow.
const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}
const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;
---

<Base title="No stories today">
  <section class="no-stories">
    <h1 class="no-stories__title">No stories today</h1>
    <p class="no-stories__message">
      We couldn't find enough fresh articles matching your interests. Try broadening
      your hashtags or adding a few more topics.
    </p>
    <a class="no-stories__link" href="/settings">Open settings</a>
  </section>
</Base>

<style>
  .no-stories {
    max-width: 560px;
    margin: 0 auto;
    padding: 3rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .no-stories__title {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .no-stories__message {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .no-stories__link {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background-color: var(--text);
    color: var(--bg);
    border-radius: 0.375rem;
    font-weight: 600;
    text-decoration: none;
  }

  .no-stories__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
