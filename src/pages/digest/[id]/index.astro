---
// Implements REQ-HIST-001
//
// Past-digest view at /digest/<id>. History rows link here; the page
// resolves the digest by id, enforces ownership via the session user,
// and renders the article cards exactly like the main /digest page
// — minus the live-poll chrome (past digests are immutable) and the
// tag strip (which is a live-filter control, not a historical one).

import type { APIContext } from 'astro';
import Base from '~/layouts/Base.astro';
import DigestCard from '~/components/DigestCard.astro';
import CostFooter from '~/components/CostFooter.astro';
import { loadSession } from '~/middleware/auth';
import { requireSettingsComplete } from '~/middleware/settings-gate';

interface DigestRow {
  id: string;
  user_id: string;
  local_date: string;
  generated_at: number;
  execution_ms: number | null;
  tokens_in: number | null;
  tokens_out: number | null;
  estimated_cost_usd: number | null;
  model_id: string;
  status: 'in_progress' | 'ready' | 'failed';
  error_code: string | null;
  trigger: string;
}

interface ArticleRow {
  id: string;
  slug: string;
  source_url: string;
  title: string;
  one_liner: string;
  details_json: string;
  source_name: string | null;
  published_at: number | null;
  rank: number;
  read_at: number | null;
  tags_json: string | null;
}

const env = Astro.locals.runtime.env;
if (typeof env.OAUTH_JWT_SECRET !== 'string' || env.OAUTH_JWT_SECRET === '') {
  return new Response('Application not configured', { status: 500 });
}

const session = await loadSession(Astro.request, env.DB, env.OAUTH_JWT_SECRET);
if (session === null) {
  return Astro.redirect('/api/auth/github/login', 303);
}
Astro.locals.user = session.user;

const gated = requireSettingsComplete({
  request: Astro.request,
  locals: Astro.locals,
} as unknown as APIContext);
if (gated !== null) {
  return gated;
}

const digestId = Astro.params['id'];
if (typeof digestId !== 'string' || digestId === '') {
  return new Response('Not found', { status: 404 });
}

// Ownership is enforced by the user_id = ? filter.
const digestRow = await env.DB
  .prepare(
    `SELECT id, user_id, local_date, generated_at, execution_ms, tokens_in,
            tokens_out, estimated_cost_usd, model_id, status, error_code, trigger
     FROM digests WHERE id = ?1 AND user_id = ?2`,
  )
  .bind(digestId, session.user.id)
  .first<DigestRow>();

if (digestRow === null) {
  return new Response('Not found', { status: 404 });
}

const articleRows = await env.DB
  .prepare(
    `SELECT id, slug, source_url, title, one_liner, details_json, source_name,
            published_at, rank, read_at, tags_json
     FROM articles WHERE digest_id = ?1 ORDER BY rank ASC`,
  )
  .bind(digestId)
  .all<ArticleRow>();

interface CardArticle {
  slug: string;
  title: string;
  one_liner: string;
  source_name: string | null;
  source_url: string;
  tags: string[];
}

function parseTags(raw: string | null): string[] {
  if (raw === null || raw === '') return [];
  try {
    const v = JSON.parse(raw) as unknown;
    if (!Array.isArray(v)) return [];
    return v.filter((x): x is string => typeof x === 'string');
  } catch {
    return [];
  }
}

const articles: CardArticle[] = (articleRows.results ?? []).map((r) => ({
  slug: r.slug,
  title: r.title,
  one_liner: r.one_liner,
  source_name: r.source_name,
  source_url: r.source_url,
  tags: parseTags(r.tags_json),
}));

// Date formatting for the page header — match the article-detail
// metadata style but spelled out ("April 22, 2026") because this is
// the page title, not a compact metadata line.
const MONTHS_LONG = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December'
];
function formatLongDate(unixSec: number): string {
  const d = new Date(unixSec * 1000);
  return `${MONTHS_LONG[d.getUTCMonth()]} ${d.getUTCDate()}, ${d.getUTCFullYear()}`;
}
const headerDate = formatLongDate(digestRow.generated_at);
---

<Base title={`Digest — ${headerDate}`}>
  <section class="past-digest">
    <nav class="past-digest__back" aria-label="Back navigation">
      <a href="/history" class="past-digest__back-link">&larr; Back to history</a>
    </nav>

    <header class="past-digest__header">
      <h1 class="past-digest__title">{headerDate}</h1>
      <p class="past-digest__meta" aria-label="Digest metadata">
        <span class="past-digest__meta-item">{articles.length} STORIES</span>
        <span class="past-digest__meta-sep" aria-hidden="true">·</span>
        <span class="past-digest__meta-item">{digestRow.trigger.toUpperCase()}</span>
      </p>
    </header>

    {
      articles.length === 0 ? (
        <p class="past-digest__empty">No articles in this digest.</p>
      ) : (
        <div class="past-digest__grid">
          {articles.map((a, i) => (
            <DigestCard
              digestId={digestRow.id}
              slug={a.slug}
              title={a.title}
              oneLiner={a.one_liner}
              sourceName={a.source_name}
              sourceUrl={a.source_url}
              tags={a.tags}
              index={i}
            />
          ))}
        </div>
      )
    }

    {
      digestRow.status === 'ready' && (
        <CostFooter
          generatedAt={digestRow.generated_at}
          tz={session.user.tz}
          executionMs={digestRow.execution_ms}
          tokensIn={digestRow.tokens_in}
          tokensOut={digestRow.tokens_out}
          estimatedCostUsd={digestRow.estimated_cost_usd}
          modelId={digestRow.model_id}
        />
      )
    }
  </section>
</Base>

<style>
  .past-digest {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .past-digest__back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
  }
  .past-digest__back-link:hover {
    color: var(--text);
  }

  .past-digest__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .past-digest__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .past-digest__meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .past-digest__meta-sep {
    opacity: 0.6;
  }

  .past-digest__empty {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
  }

  /* Same responsive grid as the live /digest page. */
  .past-digest__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .past-digest__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .past-digest__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
