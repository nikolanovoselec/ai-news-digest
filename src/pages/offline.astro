---
// Implements REQ-READ-006
//
// Dedicated offline landing page. The service worker (configured in
// astro.config.mjs with NetworkFirst for /api/* and StaleWhileRevalidate
// for /digest/*) falls back to this page when navigation to the live
// app fails. It presents a calm message and a Retry button that
// navigates back to /digest when connectivity returns.
//
// A not-modal top banner (REQ-READ-006 AC 4) is rendered here and on
// the main /digest page; both copies respect `navigator.onLine`.

import Base from '~/layouts/Base.astro';
---

<Base title="Offline">
  <section class="offline-page">
    <div class="offline-page__banner" role="status">
      You're offline — showing the last digest you viewed.
    </div>
    <div class="offline-page__body">
      <h1 class="offline-page__title">No connection</h1>
      <p class="offline-page__message">
        Reconnect to the internet to load today's digest.
      </p>
      <button
        type="button"
        class="offline-page__retry"
        data-offline-retry
      >
        Try again
      </button>
    </div>
  </section>
</Base>

<script>
  function init(): void {
    const button = document.querySelector<HTMLButtonElement>('[data-offline-retry]');
    if (button === null) return;
    if (button.dataset['bound'] === '1') return;
    button.dataset['bound'] = '1';
    button.addEventListener('click', () => {
      if (window.navigator.onLine) {
        window.location.assign('/digest');
      }
    });
    // When the browser signals connectivity restored, hop back to
    // /digest automatically.
    window.addEventListener('online', () => {
      window.location.assign('/digest');
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .offline-page {
    max-width: 560px;
    margin: 0 auto;
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .offline-page__banner {
    padding: 0.6rem 1rem;
    background-color: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-size: var(--text-sm);
  }

  .offline-page__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem 0;
    text-align: center;
  }

  .offline-page__title {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .offline-page__message {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .offline-page__retry {
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    background-color: var(--accent);
    color: #ffffff;
    border: none;
    border-radius: 0.375rem;
    font-weight: 600;
    cursor: pointer;
  }
</style>
