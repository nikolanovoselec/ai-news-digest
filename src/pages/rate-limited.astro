---
// Implements REQ-READ-006
//
// Rate-limited page: "Slow down — next refresh available in Xh Ym" with
// a live countdown and a disabled button that re-enables when the
// cooldown expires. The `seconds` query parameter is the
// `retry_after_seconds` value returned from POST /api/digest/refresh
// when the endpoint returns 429.
//
// Untrusted query input is parsed as an integer and clamped to
// 0..86400 before being echoed into the DOM — per CON-SEC-001 we never
// render arbitrary strings.

import Base from '~/layouts/Base.astro';

const url = new URL(Astro.request.url);
const rawSeconds = url.searchParams.get('seconds');

let seconds = 300; // default 5 minutes
if (rawSeconds !== null && rawSeconds !== '') {
  const parsed = Number.parseInt(rawSeconds, 10);
  if (Number.isFinite(parsed) && parsed >= 0 && parsed <= 86400) {
    seconds = parsed;
  }
}

const hours = Math.floor(seconds / 3600);
const minutes = Math.floor((seconds % 3600) / 60);
const secs = seconds % 60;
const initialLabel = hours > 0 ? `${hours}h ${minutes}m` : `${minutes}m ${secs}s`;
---

<Base title="Slow down">
  <section class="rate-limited" data-rate-limited data-seconds={String(seconds)}>
    <h1 class="rate-limited__title">Slow down</h1>
    <p class="rate-limited__message">
      You've refreshed too many times recently. Next refresh available in{' '}
      <strong data-countdown>{initialLabel}</strong>.
    </p>
    <div class="rate-limited__actions">
      <button
        type="button"
        class="rate-limited__button"
        data-retry-button
        disabled
      >
        Try again
      </button>
    </div>
  </section>
</Base>

<script>
  // Live countdown + button re-enable.

  function formatRemaining(seconds: number): string {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = seconds % 60;
    if (h > 0) return `${h}h ${m}m`;
    return `${m}m ${s}s`;
  }

  function init(): void {
    const root = document.querySelector<HTMLElement>('[data-rate-limited]');
    if (root === null) return;
    if (root.dataset['bound'] === '1') return;
    root.dataset['bound'] = '1';

    const raw = root.dataset['seconds'];
    if (raw === undefined || raw === '') return;
    const initial = Number.parseInt(raw, 10);
    if (Number.isNaN(initial)) return;

    const countdown = root.querySelector<HTMLElement>('[data-countdown]');
    const button = root.querySelector<HTMLButtonElement>('[data-retry-button]');

    const deadline = Math.floor(Date.now() / 1000) + initial;
    const tick = (): void => {
      const remaining = Math.max(0, deadline - Math.floor(Date.now() / 1000));
      if (countdown !== null) countdown.textContent = formatRemaining(remaining);
      if (remaining <= 0) {
        if (button !== null) button.disabled = false;
        window.clearInterval(handle);
      }
    };

    const handle = window.setInterval(tick, 1000);
    tick();

    if (button !== null) {
      button.addEventListener('click', () => {
        if (!button.disabled) {
          window.location.assign('/digest');
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .rate-limited {
    max-width: 560px;
    margin: 0 auto;
    padding: 3rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .rate-limited__title {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text);
  }

  .rate-limited__message {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .rate-limited__actions {
    margin-top: 0.5rem;
  }

  .rate-limited__button {
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    background-color: var(--text);
    color: var(--bg);
    border: none;
    border-radius: 0.375rem;
    font-weight: 600;
    cursor: pointer;
  }

  .rate-limited__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
