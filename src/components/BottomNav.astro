---
// Implements REQ-PWA-003
//
// Mobile bottom tab bar with Digest, History, and Settings entries.
// Visible on viewports under 768 px; hidden at the desktop breakpoint
// where `Sidebar.astro` takes over.
//
// Uses `env(safe-area-inset-bottom)` so the bar clears the iPhone home
// indicator and Android gesture navigation pill. Each tab is at least
// 44 × 44 px to satisfy REQ-DES-001 AC 5 (touch targets).

interface Props {
  /** Current pathname used to mark the active tab. */
  pathname?: string;
  /**
   * First-run onboarding: only Settings is reachable until the form is
   * completed, so hide Digest/History to avoid dead-end taps.
   */
  firstRun?: boolean;
}

const { pathname = Astro.url.pathname, firstRun = false } = Astro.props;

const allTabs: ReadonlyArray<{ href: string; label: string; match: (p: string) => boolean }> = [
  { href: '/digest', label: 'Digest', match: (p) => p === '/digest' || p.startsWith('/digest/') },
  { href: '/history', label: 'History', match: (p) => p === '/history' || p.startsWith('/history/') },
  { href: '/settings', label: 'Settings', match: (p) => p === '/settings' || p.startsWith('/settings/') }
];
const tabs = firstRun ? allTabs.filter((t) => t.href === '/settings') : allTabs;
---

<nav class="bottom-nav" aria-label="Primary">
  <ul class="bottom-nav__list">
    {
      tabs.map((tab) => {
        const active = tab.match(pathname);
        return (
          <li class="bottom-nav__item">
            <a
              href={tab.href}
              class:list={['bottom-nav__link', { 'is-active': active }]}
              aria-current={active ? 'page' : undefined}
            >
              {tab.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .bottom-nav {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 40;
    background-color: var(--surface);
    border-top: 1px solid var(--border);
    padding-bottom: env(safe-area-inset-bottom);
  }

  .bottom-nav__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bottom-nav__item {
    margin: 0;
  }

  .bottom-nav__link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0.75rem 0.5rem;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 400;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .bottom-nav__link.is-active {
    color: var(--text);
    font-weight: 600;
  }

  .bottom-nav__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  /* Desktop: the sidebar replaces the bottom nav. */
  @media (min-width: 1024px) {
    .bottom-nav {
      display: none;
    }
  }
</style>
