---
// Implements REQ-PWA-003
//
// Header user menu. Collapsible disclosure (native <details>) containing
// Settings + Log out. The trigger is a gravatar avatar keyed off the
// user's GitHub email (SHA-256 hash per gravatar.com's modern API);
// falls back to the "mystery person" silhouette when no gravatar exists
// for the address.
//
// Used in the top-right of the site header, replacing the previous
// sidebar + bottom-nav navigation.

interface Props {
  /** Authenticated user's email. Used to build the gravatar URL. */
  email: string;
  /** GitHub login shown in the aria-label for screen readers. */
  login: string;
  /** Logout form action. Overridable for tests. */
  logoutHref?: string;
}

const { email, login, logoutHref = '/api/auth/github/logout' } = Astro.props;

/**
 * Hash the normalized email with SHA-256 and return a lowercase hex
 * string. Gravatar accepts SHA-256 hashes directly since 2020; this
 * lets us stay on the Web Crypto API (no MD5 needed). Runs in the
 * Astro frontmatter — resolved at SSR time, not in the browser.
 */
async function sha256Hex(input: string): Promise<string> {
  const bytes = new TextEncoder().encode(input);
  const digest = await crypto.subtle.digest('SHA-256', bytes);
  const arr = Array.from(new Uint8Array(digest));
  return arr.map((b) => b.toString(16).padStart(2, '0')).join('');
}

const normalizedEmail = email.trim().toLowerCase();
const emailHash = await sha256Hex(normalizedEmail);
// s=80 → 80×80 px (enough for 32px @ 2.5× DPR); d=mp → "mystery person"
// silhouette fallback when no gravatar is registered for this email.
const avatarUrl = `https://www.gravatar.com/avatar/${emailHash}?s=80&d=mp`;
---

<details class="user-menu" data-user-menu>
  <summary class="user-menu__trigger focus-ring" aria-label={`${login} account menu`}>
    <img
      class="user-menu__avatar"
      src={avatarUrl}
      alt=""
      width="32"
      height="32"
      loading="lazy"
      decoding="async"
      referrerpolicy="no-referrer"
    />
  </summary>
  <div class="user-menu__panel" role="menu">
    <button
      type="button"
      class="user-menu__item user-menu__theme"
      role="menuitem"
      data-theme-toggle
      aria-label="Toggle color theme"
    >
      <span class="user-menu__theme-label" data-theme-label>Dark Mode</span>
      <span class="user-menu__theme-icon" aria-hidden="true">
        <svg
          class="user-menu__theme-svg user-menu__theme-svg--sun"
          data-theme-icon="sun"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg
          class="user-menu__theme-svg user-menu__theme-svg--moon"
          data-theme-icon="moon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </span>
    </button>
    <a
      class="user-menu__item user-menu__row"
      role="menuitem"
      href="/history"
    >
      <span>History</span>
      <span class="user-menu__row-icon" aria-hidden="true">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          {/* MDI history — https://pictogrammers.com/library/mdi/icon/history/ */}
          <path d="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3C8.03,3 4,7.03 4,12H1L4.96,16.03L9,12H6C6,8.14 9.14,5 13,5C16.86,5 20,8.14 20,12C20,15.86 16.86,19 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21C17.97,21 22,16.97 22,12C22,7.03 17.97,3 13,3Z" />
        </svg>
      </span>
    </a>
    {/* Implements REQ-STAR-003 — Starred entry between History and
        Settings with the MDI star-outline glyph on the right side. */}
    <a
      class="user-menu__item user-menu__row"
      role="menuitem"
      href="/starred"
    >
      <span>Starred</span>
      <span class="user-menu__row-icon" aria-hidden="true">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          {/* MDI star-outline — https://pictogrammers.com/library/mdi/icon/star-outline/ */}
          <path d="M12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61z" />
        </svg>
      </span>
    </a>
    <a
      class="user-menu__item user-menu__row"
      role="menuitem"
      href="/settings"
    >
      <span>Settings</span>
      <span class="user-menu__row-icon" aria-hidden="true">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          {/* MDI tune-vertical — https://pictogrammers.com/library/mdi/icon/tune-vertical/ */}
          <path d="M7 3V6H5V8H7V21H9V8H11V6H9V3H7M15 3V12H13V14H15V21H17V14H19V12H17V3H15Z" />
        </svg>
      </span>
    </a>
    <form class="user-menu__logout" method="post" action={logoutHref}>
      <button
        type="submit"
        class="user-menu__item user-menu__row user-menu__logout-button"
        role="menuitem"
      >
        <span>Log out</span>
        <span class="user-menu__row-icon" aria-hidden="true">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            {/* MDI logout — https://pictogrammers.com/library/mdi/icon/logout/ */}
            <path d="M17 7L15.59 8.41L18.17 11H8V13H18.17L15.59 15.58L17 17L22 12L17 7M4 5H12V3H4C2.9 3 2 3.9 2 5V19C2 20.1 2.9 21 4 21H12V19H4V5Z" />
          </svg>
        </span>
      </button>
    </form>
  </div>
</details>

<style>
  .user-menu {
    position: relative;
  }

  .user-menu__trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 4px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 9999px;
    cursor: pointer;
    list-style: none;
    -webkit-tap-highlight-color: transparent;
  }
  /* Strip the default triangle arrow on the <summary>. */
  .user-menu__trigger::-webkit-details-marker {
    display: none;
  }
  .user-menu__trigger::marker {
    content: '';
  }
  .user-menu__trigger:hover,
  .user-menu[open] .user-menu__trigger {
    border-color: var(--border);
  }

  .user-menu__avatar {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: var(--surface);
    display: block;
  }

  .user-menu__panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 200px;
    padding: 4px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 60;
  }

  .user-menu__item {
    display: flex;
    align-items: center;
    min-height: 40px;
    padding: 8px 12px;
    background: transparent;
    border: none;
    border-radius: 6px;
    color: var(--text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-family: inherit;
    text-align: left;
    cursor: pointer;
    width: 100%;
  }
  .user-menu__item:hover {
    background: var(--surface);
  }

  .user-menu__logout {
    margin: 0;
    padding: 0;
  }

  .user-menu__theme,
  .user-menu__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .user-menu__row-icon {
    display: inline-flex;
    align-items: center;
    color: var(--text);
  }
  .user-menu__theme-label {
    /* Match Settings / Log out colour — not muted. */
    color: var(--text);
  }
  .user-menu__theme-icon {
    display: inline-flex;
    align-items: center;
    color: var(--text);
  }
  .user-menu__theme-svg {
    display: inline-flex;
  }
  /* Default visibility: assume light theme until syncThemeLabel runs.
     When light, the button offers "Dark Mode" → show the moon. */
  .user-menu__theme-svg--sun {
    display: none;
  }
  :global([data-theme='dark']) .user-menu__theme-svg--sun {
    display: inline-flex;
  }
  :global([data-theme='dark']) .user-menu__theme-svg--moon {
    display: none;
  }
</style>

<script>
  // Theme toggling via delegated click handler on document. Works no
  // matter when [data-theme-toggle] enters the DOM (e.g., after Astro
  // view transitions re-render UserMenu), and doesn't depend on the
  // ThemeToggle.astro component's inline script shipping on pages
  // where that component isn't rendered.
  import { toggleTheme } from '~/scripts/theme-toggle';

  function handleThemeClick(e: MouseEvent): void {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const button = target.closest<HTMLButtonElement>('[data-theme-toggle]');
    if (button === null) return;
    // Let the <details> stay open so the user can see the Theme: line
    // flip, but stop propagation so the outside-click close handler
    // doesn't immediately shut the menu behind us.
    e.preventDefault();
    toggleTheme(document, localStorage, (q) => window.matchMedia(q));
  }

  // Close the <details> menu when clicking outside or pressing Escape.
  // Also keep the "Theme: light/dark" label in sync with the current theme
  // so the user sees the active state without a second click.
  /**
   * The menu item shows the *target* mode — what the user will get if
   * they click. When currently dark, the button should read "Light Mode"
   * (and show the sun); when currently light, "Dark Mode" (and show the
   * moon). Sync the label text + which icon is visible whenever
   * data-theme flips.
   */
  function syncThemeLabel(): void {
    const isDark = document.documentElement.dataset['theme'] === 'dark';
    const target = isDark ? 'Light Mode' : 'Dark Mode';
    document.querySelectorAll<HTMLElement>('[data-theme-label]').forEach((el) => {
      el.textContent = target;
    });
    document.querySelectorAll<HTMLElement>('[data-theme-icon="sun"]').forEach((el) => {
      el.style.display = isDark ? 'inline-flex' : 'none';
    });
    document.querySelectorAll<HTMLElement>('[data-theme-icon="moon"]').forEach((el) => {
      el.style.display = isDark ? 'none' : 'inline-flex';
    });
  }

  function init(): void {
    syncThemeLabel();

    // Bind the outside-click / Escape / theme-toggle handlers exactly
    // ONCE per page, regardless of how many UserMenu components mount.
    if (!document.documentElement.dataset['userMenuGlobalBound']) {
      document.documentElement.dataset['userMenuGlobalBound'] = '1';
      // Theme toggle first (capture-phase so it runs before the
      // outside-click menu-close handler).
      document.addEventListener('click', handleThemeClick, true);
      document.addEventListener('click', (e) => {
        document
          .querySelectorAll<HTMLDetailsElement>('[data-user-menu][open]')
          .forEach((menu) => {
            if (e.target instanceof Node && menu.contains(e.target)) return;
            menu.open = false;
          });
      });
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        document
          .querySelectorAll<HTMLDetailsElement>('[data-user-menu][open]')
          .forEach((menu) => {
            menu.open = false;
          });
      });
    }

    // Update the label whenever data-theme changes on <html>.
    if (!document.documentElement.dataset['userMenuObserverBound']) {
      document.documentElement.dataset['userMenuObserverBound'] = '1';
      new MutationObserver(syncThemeLabel).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      });
    }
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>
