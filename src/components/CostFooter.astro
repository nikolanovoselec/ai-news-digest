---
// Implements REQ-READ-001, REQ-GEN-008
//
// Renders the digest footer: "Generated HH:MM TZ · Xs · N tokens · ~$C · model_name".
// When Workers AI did not return token counts, upstream callers should
// pass the `estimated` flag so the numeric fields render with a `~`
// prefix (REQ-GEN-008 AC 3). `cost` is pre-rounded to 4 decimal places
// by the caller — this component only formats the surrounding string.

import { localHourMinuteInTz } from '~/lib/tz';
import { modelById } from '~/lib/models';

interface Props {
  generatedAt: number; // unix seconds
  tz: string;
  executionMs: number | null;
  tokensIn: number | null;
  tokensOut: number | null;
  estimatedCostUsd: number | null;
  modelId: string;
  /**
   * True when upstream was forced to estimate token counts because the
   * AI binding did not return usage info. Prepends `~` to token count
   * and cost.
   */
  estimated?: boolean;
}

const {
  generatedAt,
  tz,
  executionMs,
  tokensIn,
  tokensOut,
  estimatedCostUsd,
  modelId,
  estimated = false,
} = Astro.props;

const hm = localHourMinuteInTz(generatedAt, tz);
const timeLabel = `${String(hm.hour).padStart(2, '0')}:${String(hm.minute).padStart(2, '0')}`;

const seconds = executionMs !== null ? (executionMs / 1000).toFixed(1) : '—';

const totalTokens =
  tokensIn !== null && tokensOut !== null ? tokensIn + tokensOut : null;
const tokensLabel =
  totalTokens === null
    ? '—'
    : `${estimated ? '~' : ''}${totalTokens.toLocaleString('en-US')}`;

const costLabel =
  estimatedCostUsd === null
    ? '—'
    : `${estimated ? '~' : ''}$${estimatedCostUsd.toFixed(4)}`;

const model = modelById(modelId);
const modelLabel = model !== undefined ? model.name : modelId;
---

<footer class="cost-footer" data-cost-footer>
  <span class="cost-footer__text">
    Generated {timeLabel} {tz} · {seconds}s · {tokensLabel} tokens · {costLabel} · {modelLabel}
  </span>
</footer>

<style>
  .cost-footer {
    margin-top: 1.5rem;
    padding: 0.75rem 1rem;
    color: var(--text-muted);
    font-size: var(--text-sm);
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .cost-footer__text {
    display: inline-block;
    line-height: 1.5;
  }
</style>
