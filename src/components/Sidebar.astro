---
// Implements REQ-PWA-003
//
// Desktop left sidebar: Digest, History, Settings plus a logout control at
// the bottom. Visible at ≥1024 px; hidden below the desktop breakpoint where
// `BottomNav.astro` takes over.

interface Props {
  /** Current pathname used to mark the active entry. */
  pathname?: string;
  /** Href for the logout control. */
  logoutHref?: string;
  /**
   * First-run onboarding: only Settings is reachable until the form is
   * completed, so hide Digest/History to avoid dead-end clicks.
   */
  firstRun?: boolean;
}

const {
  pathname = Astro.url.pathname,
  logoutHref = '/api/auth/github/logout',
  firstRun = false,
} = Astro.props;

const allEntries: ReadonlyArray<{ href: string; label: string; match: (p: string) => boolean }> = [
  { href: '/digest', label: 'Digest', match: (p) => p === '/digest' || p.startsWith('/digest/') },
  { href: '/history', label: 'History', match: (p) => p === '/history' || p.startsWith('/history/') },
  { href: '/settings', label: 'Settings', match: (p) => p === '/settings' || p.startsWith('/settings/') }
];
const entries = firstRun ? allEntries.filter((e) => e.href === '/settings') : allEntries;
---

<aside class="sidebar" aria-label="Primary">
  <nav class="sidebar__nav">
    <ul class="sidebar__list">
      {
        entries.map((entry) => {
          const active = entry.match(pathname);
          return (
            <li class="sidebar__item">
              <a
                href={entry.href}
                class:list={['sidebar__link', { 'is-active': active }]}
                aria-current={active ? 'page' : undefined}
              >
                {entry.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
  <form class="sidebar__logout" method="post" action={logoutHref}>
    <button type="submit" class="sidebar__logout-button">Log out</button>
  </form>
</aside>

<style>
  .sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .sidebar {
      position: sticky;
      top: 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      width: 240px;
      height: 100dvh;
      padding: 1.5rem 1rem;
      padding-top: calc(1.5rem + env(safe-area-inset-top));
      padding-bottom: calc(1.5rem + env(safe-area-inset-bottom));
      border-right: 1px solid var(--border);
      background-color: var(--surface);
    }
  }

  .sidebar__nav {
    flex: 1 1 auto;
  }

  .sidebar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar__link {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    color: var(--text-muted);
    font-size: 16px;
    font-weight: 400;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .sidebar__link.is-active {
    color: var(--text);
    font-weight: 600;
    background-color: var(--bg);
  }

  .sidebar__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .sidebar__logout {
    margin: 0;
  }

  .sidebar__logout-button {
    width: 100%;
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-size: 14px;
    font-weight: 400;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .sidebar__logout-button:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .sidebar__logout-button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
