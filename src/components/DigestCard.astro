---
// Implements REQ-READ-001, REQ-READ-002
// Implements REQ-GEN-005 AC 6 (renders the validated per-article tag list)
//
// Single article card for the digest overview grid. Renders the title,
// 120-char one-liner summary, source-name badge, and an inline `#`
// disclosure that opens a non-interactive popover with the article's
// tag list (REQ-READ-001 AC 6).
//
// View Transitions: each card carries a unique `transition:name` derived
// from the article slug so Astro's ClientRouter performs a shared-element
// morph into the detail page's matching container. The detail page uses
// the same name on its title wrapper.
//
// Text is rendered as plain `{expression}` — Astro escapes by default,
// so REQ-READ-002 AC 2 (no innerHTML, no markdown parsing) is satisfied
// without extra work in this component.

interface Props {
  digestId: string;
  slug: string;
  title: string;
  oneLiner: string;
  sourceName: string | null;
  /** Outbound URL to the original article — used as the hostname
   * fallback when sourceName is null so the card never renders
   * without any source attribution. */
  sourceUrl?: string | null;
  /** Article tag list (REQ-GEN-005 AC 6). Empty array when no tags. */
  tags?: string[];
  /**
   * Zero-based index used for the 40ms-per-card stagger animation
   * (REQ-READ-001 AC 3). Values ≥10 are clamped by the CSS.
   */
  index?: number;
}

const {
  digestId,
  slug,
  title,
  oneLiner,
  sourceName,
  sourceUrl = null,
  tags = [],
  index = 0,
} = Astro.props;

const href = `/digest/${digestId}/${slug}`;
const transitionName = `card-${slug}`;
// Cap stagger at 10 cards per REQ-READ-001 AC 3 — anything beyond that
// animates at the same 400ms offset.
const stagger = Math.min(index, 9);
// data-tags is the filter contract with the tag-strip script on
// digest.astro: a comma-joined list so the script can intersect against
// the selected-tag set without re-parsing JSON per card.
const tagAttr = tags.join(',');

/** Resolve the badge text shown at the bottom-left of the card.
 *  Preference order: the fan-out source_name (minus the `feed:`
 *  namespace prefix) → the source-URL hostname minus `www.`. Only
 *  returns the empty string when every fallback is missing. Pure
 *  display logic — doesn't mutate the DB. */
function resolveDisplaySource(): string {
  if (sourceName !== null && sourceName !== '') {
    return sourceName.startsWith('feed:')
      ? sourceName.slice('feed:'.length)
      : sourceName;
  }
  if (typeof sourceUrl === 'string' && sourceUrl !== '') {
    try {
      const host = new URL(sourceUrl).host;
      return host.replace(/^www\./, '');
    } catch {
      return '';
    }
  }
  return '';
}
const displaySourceName = resolveDisplaySource();
---

<article
  class="digest-card"
  data-digest-card
  data-stagger-index={stagger}
  data-tags={tagAttr}
  style={`--stagger-delay: ${stagger * 40}ms`}
>
  <a
    class="digest-card__link"
    href={href}
    transition:name={transitionName}
    aria-label={title}
  >
    <h2 class="digest-card__title">{title}</h2>
    <p class="digest-card__one-liner">{oneLiner}</p>
    <footer class="digest-card__footer">
      {
        displaySourceName !== null && displaySourceName !== '' && (
          <span class="digest-card__source">{displaySourceName}</span>
        )
      }
      {
        tags.length > 0 && (
          <div class="digest-card__tag-disclosure" data-tag-disclosure>
            <button
              type="button"
              class="digest-card__tag-trigger"
              data-tag-trigger
              aria-label={`Show tags for ${title}`}
              aria-expanded="false"
            >
              #
            </button>
            <div class="digest-card__tag-popover" role="region">
              {tags.map((t) => (
                <span class="digest-card__tag-chip">#{t}</span>
              ))}
            </div>
          </div>
        )
      }
    </footer>
  </a>
</article>

<style>
  .digest-card {
    position: relative;
    background-color: var(--surface);
    /* Hairline vertical gradient for dark-mode depth — 2% white at
       the top fading to transparent gives a faint "paper under lamp"
       highlight so cards don't read as flat rectangles. On light
       theme the effect is near-imperceptible; on dark it's the
       difference between "dashboard" and "evening paper". */
    background-image: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.02),
      transparent 40%
    );
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    /* Default: rendered visible. The entrance stagger only fires on
       the very first dashboard paint (see the
       :root:not([data-digest-seen]) rule below) so the back-from-
       detail View Transition doesn't replay the fade and make the
       grid flicker. Non-selected cards still morph cleanly via VT;
       the hit card uses its own transition:name to shared-element
       back into the grid. */
    opacity: 1;
  }

  /* Only play the fade-in-stagger on the first dashboard paint. The
     mark-seen script on digest.astro sets data-digest-seen on <html>
     after the initial animation frame, and Astro's View Transitions
     preserve <html> so subsequent returns to /digest skip this rule
     entirely. */
  :root:not([data-digest-seen]) .digest-card {
    opacity: 0;
    animation: digest-card-enter 240ms ease-out both;
    animation-delay: var(--stagger-delay, 0ms);
  }

  .digest-card__link {
    display: flex;
    flex-direction: column;
    /* Equal 1rem rhythm inside the card so title ↔ one-liner ↔ footer
       spacing matches the between-card gap on the grid; the user
       reads cards as blocks rather than floating boxes. */
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    color: var(--text);
    text-decoration: none;
    min-height: 140px;
    min-width: 0;
  }

  /* Footer row anchors to the card's bottom via margin-top: auto and
     is a flex row: source on the left, # tag-disclosure on the right.
     When a card is shorter than the min-height, the footer still
     pins to the bottom edge so cards read as aligned blocks. */
  .digest-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
  }

  .digest-card:hover {
    border-color: var(--text-muted);
  }

  .digest-card__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  .digest-card__title {
    margin: 0;
    /* Editorial serif — same family as the article-detail headline
       and the dashboard "Today's digest" anchor, so the card reads
       as a mini-front-page teaser rather than a generic list row. */
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    min-width: 0;
    text-wrap: balance;
  }

  /* Tag disclosure: plain <div> wrapper + <button> trigger. The
     popover is always in the DOM with visibility: hidden; CSS flips
     visibility + opacity on :hover (desktop) or .is-open (mobile,
     set by the client script). Simpler and more predictable than
     <details>, whose UA rule `display: none` on non-open children
     fought the :hover rule on specificity. */
  .digest-card__tag-disclosure {
    position: relative;
    flex-shrink: 0;
  }

  /* Demote the # to a lightweight muted glyph — no box, no border,
     just a clickable character. It's a secondary affordance; the
     article title owns the card's visual weight. Hitbox stays
     comfortably large via padding on the <summary>, not a min-size
     box. */
  .digest-card__tag-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 4px;
    min-width: 0;
    min-height: 0;
    background: transparent;
    border: 0;
    border-radius: 3px;
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: inherit;
    line-height: 1;
    opacity: 0.65;
    user-select: none;
    transition: opacity 150ms ease, color 150ms ease;
  }
  .digest-card__tag-trigger:hover {
    color: var(--text);
    opacity: 1;
  }
  .digest-card__tag-disclosure.is-open .digest-card__tag-trigger {
    color: var(--text);
    opacity: 1;
  }

  .digest-card__one-liner {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.45;
  }

  /* Source name gets a small-caps treatment — no pill, no background.
     It's metadata, not an interactive control, and de-pilling it lets
     the card's real pills (tag chips) own the "clickable" affordance
     without visual competition. */
  /* Source name — small-caps metadata that matches the article-
     detail page's metadata line. Sits at the bottom-left of the card
     via the footer row. */
  .digest-card__source {
    display: inline-block;
    padding: 0;
    background: transparent;
    color: var(--text-muted);
    border: 0;
    border-radius: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Popover — always in the DOM, hidden via visibility + opacity so
     CSS :hover can toggle it without fighting a UA display:none rule.
     Anchored to the bottom-right of the # trigger and opens UPWARD
     so it never clips below the grid. */
  .digest-card__tag-popover {
    position: absolute;
    bottom: calc(100% + 6px);
    right: 0;
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 6px 8px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    max-width: min(260px, 80vw);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    visibility: hidden;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 150ms var(--ease, ease),
      transform 150ms var(--ease, ease),
      visibility 0s linear 150ms;
    pointer-events: none;
  }
  .digest-card__tag-disclosure.is-open .digest-card__tag-popover {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0s;
    pointer-events: auto;
  }
  /* Desktop (hover-capable) — popover opens on hover without any JS.
     Mobile keeps the click-to-open flow via the .is-open class, set
     by the script at the bottom of this file. */
  @media (hover: hover) and (pointer: fine) {
    .digest-card__tag-disclosure:hover .digest-card__tag-popover {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0s;
      pointer-events: auto;
    }
  }

  .digest-card__tag-chip {
    display: inline-block;
    padding: 2px 8px;
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  @keyframes digest-card-enter {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :root:not([data-digest-seen]) .digest-card {
      opacity: 1;
      animation: none;
    }
  }

  /* Hide a card when the tag-strip filter is active and the card's
     tag list does not intersect the selection. The digest.astro script
     sets data-filter-hide on miss. */
  .digest-card[data-filter-hide='1'] {
    display: none;
  }
</style>

<script>
  // Mobile click-to-open with 5s auto-close. Desktop (hover-capable
  // devices) shows the popover via CSS :hover — no script needed
  // there. The script still runs on desktop to catch click taps
  // which "pin" the popover open until a click-outside closes it.
  const POPOVER_TTL_MS = 5000;
  const timers = new WeakMap<HTMLElement, number>();

  function closeAll(except?: HTMLElement): void {
    document
      .querySelectorAll<HTMLElement>('[data-tag-disclosure].is-open')
      .forEach((d) => {
        if (d === except) return;
        d.classList.remove('is-open');
        const trigger = d.querySelector<HTMLButtonElement>('[data-tag-trigger]');
        if (trigger !== null) trigger.setAttribute('aria-expanded', 'false');
        const existing = timers.get(d);
        if (existing !== undefined) {
          window.clearTimeout(existing);
          timers.delete(d);
        }
      });
  }

  function init(): void {
    if (document.documentElement.dataset['tagDisclosureBound'] === '1') return;
    document.documentElement.dataset['tagDisclosureBound'] = '1';

    // Capture-phase click: the trigger lives inside the card's <a>,
    // so we must preventDefault + stopPropagation BEFORE the anchor's
    // own navigation fires.
    document.addEventListener(
      'click',
      (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const trigger = target.closest<HTMLButtonElement>('[data-tag-trigger]');
        if (trigger === null) {
          // Click outside any trigger: close every open popover.
          if (target.closest('[data-tag-disclosure]') === null) closeAll();
          return;
        }
        e.preventDefault();
        e.stopPropagation();
        const disclosure = trigger.closest<HTMLElement>('[data-tag-disclosure]');
        if (disclosure === null) return;
        const willOpen = !disclosure.classList.contains('is-open');
        closeAll(willOpen ? disclosure : undefined);
        if (willOpen) {
          disclosure.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
          const t = window.setTimeout(() => {
            disclosure.classList.remove('is-open');
            trigger.setAttribute('aria-expanded', 'false');
            timers.delete(disclosure);
          }, POPOVER_TTL_MS);
          timers.set(disclosure, t);
        }
      },
      true,
    );
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
