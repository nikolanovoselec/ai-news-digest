---
// Implements REQ-READ-001, REQ-READ-002
//
// Single article card for the digest overview grid. Renders the title,
// 120-char one-liner summary, and source-name badge. The entire card
// is a link to the detail route so the whole surface is clickable.
//
// View Transitions: each card carries a unique `transition:name` derived
// from the article slug so Astro's ClientRouter performs a shared-element
// morph into the detail page's matching container. The detail page uses
// the same name on its title wrapper.
//
// Text is rendered as plain `{expression}` — Astro escapes by default,
// so REQ-READ-002 AC 2 (no innerHTML, no markdown parsing) is satisfied
// without extra work in this component.

interface Props {
  digestId: string;
  slug: string;
  title: string;
  oneLiner: string;
  sourceName: string | null;
  /**
   * Zero-based index used for the 40ms-per-card stagger animation
   * (REQ-READ-001 AC 3). Values ≥10 are clamped by the CSS.
   */
  index?: number;
}

const { digestId, slug, title, oneLiner, sourceName, index = 0 } = Astro.props;

const href = `/digest/${digestId}/${slug}`;
const transitionName = `card-${slug}`;
// Cap stagger at 10 cards per REQ-READ-001 AC 3 — anything beyond that
// animates at the same 400ms offset.
const stagger = Math.min(index, 9);
---

<a
  class="digest-card"
  href={href}
  data-digest-card
  data-stagger-index={stagger}
  style={`--stagger-delay: ${stagger * 40}ms`}
  transition:name={transitionName}
>
  <h2 class="digest-card__title">{title}</h2>
  <p class="digest-card__one-liner">{oneLiner}</p>
  {
    sourceName !== null && sourceName !== '' && (
      <span class="digest-card__source">{sourceName}</span>
    )
  }
</a>

<style>
  .digest-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    color: var(--text);
    text-decoration: none;
    min-height: 140px;
    opacity: 0;
    animation: digest-card-enter 240ms ease-out both;
    animation-delay: var(--stagger-delay, 0ms);
  }

  .digest-card:hover {
    border-color: var(--text-muted);
  }

  .digest-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .digest-card__title {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.3;
  }

  .digest-card__one-liner {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.45;
  }

  .digest-card__source {
    display: inline-block;
    align-self: flex-start;
    margin-top: auto;
    padding: 0.15rem 0.5rem;
    background-color: var(--bg);
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 400;
  }

  @keyframes digest-card-enter {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* REQ-READ-001 AC 3 — reduce motion disables stagger entirely. */
  @media (prefers-reduced-motion: reduce) {
    .digest-card {
      opacity: 1;
      animation: none;
    }
  }
</style>
