---
// Implements REQ-READ-001, REQ-READ-002
// Implements REQ-GEN-005 AC 6 (renders the validated per-article tag list)
//
// Single article card for the digest overview grid. Renders the title,
// 120-char one-liner summary, source-name badge, and an inline `#`
// disclosure that opens a non-interactive popover with the article's
// tag list (REQ-READ-001 AC 6).
//
// View Transitions: each card carries a unique `transition:name` derived
// from the article slug so Astro's ClientRouter performs a shared-element
// morph into the detail page's matching container. The detail page uses
// the same name on its title wrapper.
//
// Text is rendered as plain `{expression}` — Astro escapes by default,
// so REQ-READ-002 AC 2 (no innerHTML, no markdown parsing) is satisfied
// without extra work in this component.

interface Props {
  digestId: string;
  slug: string;
  title: string;
  oneLiner: string;
  sourceName: string | null;
  /** Article tag list (REQ-GEN-005 AC 6). Empty array when no tags. */
  tags?: string[];
  /**
   * Zero-based index used for the 40ms-per-card stagger animation
   * (REQ-READ-001 AC 3). Values ≥10 are clamped by the CSS.
   */
  index?: number;
}

const {
  digestId,
  slug,
  title,
  oneLiner,
  sourceName,
  tags = [],
  index = 0,
} = Astro.props;

const href = `/digest/${digestId}/${slug}`;
const transitionName = `card-${slug}`;
// Cap stagger at 10 cards per REQ-READ-001 AC 3 — anything beyond that
// animates at the same 400ms offset.
const stagger = Math.min(index, 9);
// data-tags is the filter contract with the tag-strip script on
// digest.astro: a comma-joined list so the script can intersect against
// the selected-tag set without re-parsing JSON per card.
const tagAttr = tags.join(',');
// Discovered-feed source names are stored as `feed:<slug>` so fan-out
// can dedupe them separately; the slug is all users need to see.
const displaySourceName =
  sourceName !== null && sourceName.startsWith('feed:')
    ? sourceName.slice('feed:'.length)
    : sourceName;
---

<article
  class="digest-card"
  data-digest-card
  data-stagger-index={stagger}
  data-tags={tagAttr}
  style={`--stagger-delay: ${stagger * 40}ms`}
>
  <a
    class="digest-card__link"
    href={href}
    transition:name={transitionName}
    aria-label={title}
  >
    <div class="digest-card__heading">
      {
        /* `<details>` native click-toggle — no JS required to open or
           close. Positioned inline with the title, click on the `#`
           opens the popover; click again closes; auto-close after 5 s
           via the light script below. */
      }
      {
        tags.length > 0 && (
          <details class="digest-card__tag-details" data-tag-details>
            <summary
              class="digest-card__tag-trigger"
              aria-label={`Show tags for ${title}`}
            >
              #
            </summary>
            <div class="digest-card__tag-popover">
              {tags.map((t) => (
                <span class="digest-card__tag-chip">#{t}</span>
              ))}
            </div>
          </details>
        )
      }
      <h2 class="digest-card__title">{title}</h2>
    </div>
    <p class="digest-card__one-liner">{oneLiner}</p>
    {
      displaySourceName !== null && displaySourceName !== '' && (
        <span class="digest-card__source">{displaySourceName}</span>
      )
    }
  </a>
</article>

<style>
  .digest-card {
    position: relative;
    background-color: var(--surface);
    /* Hairline vertical gradient for dark-mode depth — 2% white at
       the top fading to transparent gives a faint "paper under lamp"
       highlight so cards don't read as flat rectangles. On light
       theme the effect is near-imperceptible; on dark it's the
       difference between "dashboard" and "evening paper". */
    background-image: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.02),
      transparent 40%
    );
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    opacity: 0;
    animation: digest-card-enter 240ms ease-out both;
    animation-delay: var(--stagger-delay, 0ms);
  }

  .digest-card__link {
    display: flex;
    flex-direction: column;
    /* Equal 1rem rhythm inside the card so the title ↔ one-liner ↔
       source spacing matches the between-card gap on the grid; the
       user reads cards as blocks rather than floating boxes. */
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    color: var(--text);
    text-decoration: none;
    min-height: 140px;
    min-width: 0;
  }

  .digest-card:hover {
    border-color: var(--text-muted);
  }

  .digest-card__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  .digest-card__heading {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    position: relative;
  }

  .digest-card__title {
    margin: 0;
    /* Editorial serif — same family as the article-detail headline
       and the dashboard "Today's digest" anchor, so the card reads
       as a mini-front-page teaser rather than a generic list row. */
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    flex: 1 1 auto;
    min-width: 0;
    text-wrap: balance;
  }

  /* Native <details> disclosure for the tag popover. `position:
     static` on the element, `position: absolute` on the popover so it
     floats over the card without pushing the title. */
  .digest-card__tag-details {
    flex-shrink: 0;
  }
  .digest-card__tag-details summary {
    list-style: none;
    cursor: pointer;
  }
  .digest-card__tag-details summary::-webkit-details-marker {
    display: none;
  }

  /* Demote the # to a lightweight muted glyph — no box, no border,
     just a clickable character. It's a secondary affordance; the
     article title owns the card's visual weight. Hitbox stays
     comfortably large via padding on the <summary>, not a min-size
     box. */
  .digest-card__tag-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 4px;
    min-width: 0;
    min-height: 0;
    background: transparent;
    border: 0;
    border-radius: 3px;
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: inherit;
    line-height: 1;
    opacity: 0.65;
    user-select: none;
    transition: opacity 150ms ease, color 150ms ease;
  }
  .digest-card__tag-trigger:hover {
    color: var(--text);
    opacity: 1;
  }
  .digest-card__tag-details[open] .digest-card__tag-trigger {
    color: var(--text);
    opacity: 1;
  }

  .digest-card__one-liner {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-base);
    line-height: 1.45;
  }

  /* Source name gets a small-caps treatment — no pill, no background.
     It's metadata, not an interactive control, and de-pilling it lets
     the card's real pills (tag chips) own the "clickable" affordance
     without visual competition. */
  .digest-card__source {
    display: inline-block;
    align-self: flex-start;
    margin-top: auto;
    padding: 0;
    background: transparent;
    color: var(--text-muted);
    border: 0;
    border-radius: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .digest-card__tag-popover {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 6px 8px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    max-width: calc(100% - 0px);
  }

  .digest-card__tag-chip {
    display: inline-block;
    padding: 2px 8px;
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  @keyframes digest-card-enter {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .digest-card {
      opacity: 1;
      animation: none;
    }
  }

  /* Hide a card when the tag-strip filter is active and the card's
     tag list does not intersect the selection. The digest.astro script
     sets data-filter-hide on miss. */
  .digest-card[data-filter-hide='1'] {
    display: none;
  }
</style>

<script>
  // Pure progressive enhancement on top of the native <details>:
  //   * stop the click from navigating the parent <a> (details is
  //     inside the anchor so the toggle propagates),
  //   * auto-close the popover 5 s after open,
  //   * close other open popovers so only one is visible at a time.
  // If this script never runs, the popover still toggles natively on
  // click — the user keeps the core behaviour.
  const POPOVER_TTL_MS = 5000;
  const timers = new WeakMap<HTMLDetailsElement, number>();

  function init(): void {
    if (document.documentElement.dataset['tagDetailsBound'] === '1') return;
    document.documentElement.dataset['tagDetailsBound'] = '1';
    document.addEventListener(
      'click',
      (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const summary = target.closest('summary');
        if (summary === null) return;
        const details = summary.closest<HTMLDetailsElement>('[data-tag-details]');
        if (details === null) return;
        // Stop the anchor navigation — the <details> lives inside the
        // card's <a>.
        e.preventDefault();
        e.stopPropagation();
      },
      true,
    );
    document.addEventListener('toggle', (e) => {
      const details = e.target;
      if (!(details instanceof HTMLDetailsElement)) return;
      if (details.dataset['tagDetails'] === undefined) return;
      const existing = timers.get(details);
      if (existing !== undefined) window.clearTimeout(existing);
      if (!details.open) {
        timers.delete(details);
        return;
      }
      // Close every other open popover.
      document
        .querySelectorAll<HTMLDetailsElement>('[data-tag-details][open]')
        .forEach((d) => {
          if (d !== details) d.open = false;
        });
      const t = window.setTimeout(() => { details.open = false; }, POPOVER_TTL_MS);
      timers.set(details, t);
    }, true);
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
