    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.0",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "fast-xml-parser": "^5.0.9",
    "tailwindcss": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260422.1",
    "@types/node": "^25.6.0",
    "@vite-pwa/astro": "^1.2.0",
    "knip": "^6.6.1",
    "oxlint": "^1.61.0",
    "typescript": "^5.7.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
