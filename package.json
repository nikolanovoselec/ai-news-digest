{
  "name": "news-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/ tests/ --deny-warnings",
    "lint:fix": "oxlint src/ tests/ --fix",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.1",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.14.0",
    "fast-xml-parser": "^5.0.9",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^22.10.5",
    "@vite-pwa/astro": "^0.5.6",
    "knip": "^5.65.0",
    "oxlint": "^0.15.15",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.40.0"
  }
